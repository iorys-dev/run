# ──────────────────────────────────────────────────────────────────────────────
# iorys/run — environment variables
#
# Copy this file to .env in your project root and fill in the required values.
# All Cloudflare Tunnel vars marked "auto" are written by `./run tunnel up`
# and should be left empty initially.
# ──────────────────────────────────────────────────────────────────────────────

# ── Project identity ──────────────────────────────────────────────────────────

# Slug used in tunnel subdomain: {APP_PROJECT}-{APP_NAMESPACE}.iorys.dev
# e.g. "ledger", "iportal", "hub"
APP_PROJECT=myproject

# Short developer identifier appended to subdomains (e.g. your initials).
# Leave empty to auto-generate a random 7-char string on first `./run tunnel up`.
APP_NAMESPACE=

# ── Cloudflare API credentials ────────────────────────────────────────────────
# Required to create / destroy tunnel and DNS records.
#
# Create a token at: dash.cloudflare.com → My Profile → API Tokens
# Required permissions:
#   Account > Cloudflare Tunnel > Edit
#   Zone    > DNS               > Edit  (for zone: iorys.dev)
#
CF_API_TOKEN=
CF_ACCOUNT_ID=

# ── Cloudflare Tunnel state (written automatically by `./run tunnel up`) ──────
# Do not fill these in manually — leave them empty.
# `./run tunnel up`  populates them.
# `./run tunnel down` clears them.

CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_TOKEN=

# One entry per service labelled cf_expose=true in docker-compose.yml.
# Key format: CLOUDFLARE_DNS_RECORD_{SERVICE_NAME_UPPER}
# Examples (actual values written by tunnel-up.sh):
CLOUDFLARE_DNS_RECORD_NGINX=
# CLOUDFLARE_DNS_RECORD_PORTAL=
# CLOUDFLARE_DNS_RECORD_PORTAL_STATIC=
